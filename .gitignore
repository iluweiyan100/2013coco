# 忽略 node_modules
node_modules/
cloudfunctions/*/node_modules/

# 忽略编译产物
*.wcc
*.wxmlc
.tmproj
*.sublime-project
*.sublime-workspace

# 忽略系统文件
.DS_Store
Thumbs.db
.idea/
*.iml

# 忽略日志文件
*.log
logs/

# 忽略临时文件
*.tmp
*.swp
*.bak

# 忽略 VSCode 特定文件
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
