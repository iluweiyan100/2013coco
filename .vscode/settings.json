{
    "codingcopilot.enableWorkspaceRules": true,
    "augment.advanced": {
        "mcpServers": [
            {
                "name": "cloudbase",
                "command": "npx",
                "args": [
                    "npm-global-exec@latest",
                    "@cloudbase/cloudbase-mcp@latest"
                ],
                "env": {
                    "INTEGRATION_IDE": "Augment"
                }
            }
        ]
    },
    // 文件关联，让 VSCode 正确识别小程序文件
    "files.associations": {
        "*.wxss": "css",
        "*.wxml": "html",
        "*.wxs": "javascript"
    },
    
    // Emmet 支持 WXML
    "emmet.includeLanguages": {
        "wxml": "html"
    },
    
    // 自动保存
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000
}
