/* admin.wxss */

page {
  background: #F9F5F0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei UI', 'Microsoft YaHei', Arial, sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===== 主滚动区 ===== */
.admin-scroll {
  flex: 1;
  overflow-y: hidden;
}

.admin-body {
  padding: 32rpx 48rpx 48rpx;
}

/* ===== Tab 切换栏 ===== */
.tab-bar {
  display: flex;
  background: #E7DDD1;
  border-radius: 32rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
}

.tab-active {
  background: #A3212D;
}

.tab-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #5B3A29;
}

.tab-text-active {
  color: #FFFFFF;
}

/* ===== Tab 内容区 ===== */
.tab-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.placeholder-text {
  text-align: center;
  color: #8B6F5E;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* ===== 统计卡片 ===== */
.stat-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
}

.stat-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.stat-icon-red   { background: rgba(163, 33, 45, 0.10); }
.stat-icon-gold  { background: rgba(192, 138, 77, 0.10); }
.stat-icon-brown { background: rgba(91, 58, 41, 0.10); }

.stat-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.stat-card-label {
  font-size: 32rpx;
  color: rgba(91, 58, 41, 0.60);
}

.stat-card-value {
  font-size: 60rpx;
  font-weight: 400;
}

.stat-value-red   { color: #A3212D; }
.stat-value-gold  { color: #C08A4D; }
.stat-value-brown { color: #5B3A29; }

/* ===== 商品销售排行 ===== */
.ranking-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
}

.ranking-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #5B3A29;
  margin-bottom: 32rpx;
  display: block;
}

.ranking-list {
  display: flex;
  flex-direction: column;
}

.ranking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.ranking-row-border {
  border-bottom: 1rpx solid #E7DDD1;
}

.ranking-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.rank-badge-1 { background: #A3212D; }
.rank-badge-2 { background: #C08A4D; }
.rank-badge-3 { background: #5B3A29; }
.rank-badge-other { background: #E7DDD1; }

.rank-num {
  font-size: 24rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.rank-name {
  font-size: 28rpx;
  color: #5B3A29;
}

.ranking-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.rank-sales {
  font-size: 24rpx;
  color: rgba(91, 58, 41, 0.60);
  margin-bottom: 8rpx;
}

.rank-revenue {
  font-size: 28rpx;
  font-weight: 500;
  color: #C08A4D;
}

/* ===== 商品管理 Tab ===== */
.category-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.category-btn {
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  background: #E7DDD1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-btn-active {
  background: #A3212D;
}

.category-btn-text {
  font-size: 24rpx;
  color: #5B3A29;
}

.category-btn-text-active {
  color: #FFFFFF;
}

.add-product-btn {
  height: 80rpx;
  background: #A3212D;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.add-product-icon {
  width: 36rpx;
  height: 36rpx;
}

.add-product-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.products-loading,
.products-empty {
  padding: 60rpx 0;
  text-align: center;
}

.products-loading-text,
.products-empty-text {
  font-size: 26rpx;
  color: #999;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

.product-card-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F0E8DF;
}

.product-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3A2318;
  display: block;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.product-price {
  font-size: 26rpx;
  color: #A3212D;
  font-weight: 500;
}

.product-tag {
  background: #F5EDE4;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
}

.product-tag-text {
  font-size: 22rpx;
  color: #8B6F5E;
}

.product-status-tag {
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
}

.product-status-on   { background: rgba(39, 167, 79, 0.12); }
.product-status-off  { background: rgba(91, 58, 41, 0.10); }
.product-status-sold { background: rgba(163, 33, 45, 0.10); }

.product-status-text {
  font-size: 22rpx;
}

.product-status-on   .product-status-text { color: #27A74F; }
.product-status-off  .product-status-text { color: #8B6F5E; }
.product-status-sold .product-status-text { color: #A3212D; }

.product-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.product-action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F5EDE4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-action-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ===== 新增/编辑商品弹窗 ===== */
.pm-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}

.pm-box {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  max-height: 88vh;
}

.pm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 48rpx 24rpx;
  flex-shrink: 0;
}

.pm-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3A2318;
}

.pm-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pm-close-icon {
  width: 32rpx;
  height: 32rpx;
}

.pm-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 48rpx;
  box-sizing: border-box;
  width: 100%;
}

.pm-field {
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.pm-label {
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.60);
  display: block;
  margin-bottom: 12rpx;
}

.pm-upload-area {
  width: 240rpx;
  height: 240rpx;
  border: 2rpx dashed #C9A98A;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FAF6F2;
  overflow: hidden;
  box-sizing: border-box;
}

.pm-upload-icon {
  width: 96rpx;
  height: 96rpx;
}

.pm-upload-tip {
  font-size: 26rpx;
  color: #8B6F5E;
  margin-bottom: 8rpx;
}

.pm-upload-hint {
  font-size: 22rpx;
  color: rgba(139, 111, 94, 0.60);
}

.pm-preview-img {
  width: 100%;
  height: 100%;
}

.pm-input {
  width: 100%;
  height: 80rpx;
  background: #F5EDE4;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #3A2318;
  box-sizing: border-box;
}

.pm-placeholder {
  color: rgba(58, 35, 24, 0.35);
}

.pm-picker {
  width: 100%;
  box-sizing: border-box;
}

.pm-picker-inner {
  width: 100%;
  height: 80rpx;
  background: #F5EDE4;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.pm-picker-text {
  font-size: 28rpx;
  color: #3A2318;
}

.pm-picker-arrow {
  font-size: 24rpx;
  color: #8B6F5E;
}

.pm-status-group {
  display: flex;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.pm-status-btn {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E7DDD1;
  background: #FAFAFA;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.pm-status-active {
  border-color: #A3212D;
  background: rgba(163, 33, 45, 0.08);
}

.pm-status-text {
  font-size: 26rpx;
  color: #8B6F5E;
}

.pm-status-text-active {
  color: #A3212D;
  font-weight: 500;
}

.pm-field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

/* 勾选框组（温度选项、拼球选项） */
.pm-checkbox-group {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 24rpx;
}

.pm-checkbox-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pm-checkbox-label {
  font-size: 28rpx;
  color: #3A2318;
}

/* 旧的冰热同行布局（保留兼容） */
.pm-price-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 24rpx;
}

.pm-price-col {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.pm-input-short {
  width: 100% !important;
}

.pm-icehot-col {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  width: 160rpx;
}

.pm-icehot-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  height: 80rpx;
}

.pm-label-inline {
  display: inline;
  margin-bottom: 0;
}

.pm-checkbox {
  flex-shrink: 0;
}

.pm-checkbox-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  border: 2rpx solid #C9A98A;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pm-checkbox-checked {
  background: #A3212D;
  border-color: #A3212D;
}

.pm-checkbox-tick {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1;
}

.pm-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 48rpx 48rpx;
  flex-shrink: 0;
}

.pm-save-btn {
  flex: 1;
  height: 88rpx;
  background: #A3212D;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pm-save-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.pm-cancel-btn {
  flex: 1;
  height: 88rpx;
  background: #F5EDE4;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pm-cancel-text {
  font-size: 30rpx;
  color: #8B6F5E;
}

/* ===== 订单管理 Tab ===== */
.order-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.order-filter-btn {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #E7DDD1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-filter-btn-active {
  background: #A3212D;
}

.order-filter-text {
  font-size: 24rpx;
  color: #5B3A29;
}

.order-filter-text-active {
  color: #FFFFFF;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-header-left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

.order-status-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #FFF5E6;
  border-radius: 10rpx;
  padding: 6rpx 16rpx;
}

.order-status-icon {
  width: 28rpx;
  height: 28rpx;
}

.order-status-text {
  font-size: 24rpx;
  color: #C08A4D;
  font-weight: 500;
}

.order-pickup-no {
  display: flex;
  align-items: center;
}

.order-pickup-label {
  font-size: 22rpx;
  color: rgba(58, 35, 24, 0.50);
}

.order-pickup-num {
  font-size: 26rpx;
  font-weight: 600;
  color: #3A2318;
}

.order-type-tag {
  background: #F0E8DF;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
}

.order-type-text {
  font-size: 22rpx;
  color: #8B6F5E;
}

.order-refund-btn {
  background: rgba(163, 33, 45, 0.08);
  border-radius: 12rpx;
  padding: 10rpx 24rpx;
  flex-shrink: 0;
}

.order-refund-text {
  font-size: 24rpx;
  color: #A3212D;
}

.order-user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-user-text {
  font-size: 24rpx;
  color: rgba(58, 35, 24, 0.60);
}

.order-time-text {
  font-size: 22rpx;
  color: rgba(58, 35, 24, 0.45);
}

.order-items-divider {
  height: 1rpx;
  background: #F0E8DF;
  margin-bottom: 16rpx;
}

.order-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.order-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-item-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.order-item-name {
  font-size: 26rpx;
  color: #3A2318;
}

.order-item-temp {
  font-size: 22rpx;
  color: rgba(58, 35, 24, 0.50);
  background: #F0E8DF;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.order-item-qty {
  font-size: 24rpx;
  color: rgba(58, 35, 24, 0.50);
}

.order-item-price {
  font-size: 26rpx;
  color: #3A2318;
  font-weight: 500;
}

.order-total-divider {
  height: 1rpx;
  background: #F0E8DF;
  margin-bottom: 16rpx;
}

.order-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-total-label {
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.60);
}

.order-total-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #A3212D;
}

/* ===== 首页内容 Tab ===== */
.home-settings-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

.home-settings-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #3A2318;
  display: block;
  margin-bottom: 40rpx;
}

.home-form-body {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.home-form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.home-form-label {
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.60);
}

.home-form-input {
  height: 80rpx;
  background: #F5EDE4;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #3A2318;
  box-sizing: border-box;
}

.home-form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.home-action-save {
  flex: 1;
  height: 88rpx;
  background: #A3212D;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-action-save-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.home-action-cancel {
  flex: 1;
  height: 88rpx;
  background: #F5EDE4;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-action-cancel-text {
  font-size: 30rpx;
  color: #8B6F5E;
}

/* ===== 英雄区轮播图编辑 ===== */
.home-hero-card {
  margin-bottom: 24rpx;
}

.home-hero-hint {
  font-size: 24rpx;
  color: rgba(58, 35, 24, 0.45);
  display: block;
  margin-top: -28rpx;
  margin-bottom: 32rpx;
}

.hero-img-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.hero-img-item {
  position: relative;
  width: 192rpx;
  height: 128rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.hero-img-thumb {
  width: 100%;
  height: 100%;
}

.hero-img-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-img-delete-text {
  font-size: 22rpx;
  color: #FFFFFF;
  line-height: 1;
}

.hero-img-add {
  width: 192rpx;
  height: 128rpx;
  border-radius: 16rpx;
  background: #F5EDE4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.hero-img-add-icon {
  font-size: 40rpx;
  color: #A3212D;
  line-height: 1;
}

.hero-img-add-text {
  font-size: 22rpx;
  color: rgba(58, 35, 24, 0.55);
}