<!--cart.wxml-->

<!-- 顶部自定义导航栏，与胶囊按钮同高 -->
<navigation-bar title="购物车" back="{{true}}" color="#5B3A29" background="#F9F6F0"></navigation-bar>

<view class="cart-page">

  <!-- 空购物车 -->
  <view wx:if="{{cartList.length === 0}}" class="cart-empty">
    <image src="/images/icons/cart.png" class="cart-empty-icon" mode="aspectFit"></image>
    <text class="cart-empty-text">购物车还是空的</text>
    <text class="cart-empty-hint">快去点单页添加喜欢的饮品吧～</text>
    <view class="cart-empty-btn" bindtap="onGoOrder">
      <text class="cart-empty-btn-text">去点单</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <block wx:else>
    <scroll-view class="cart-scroll" scroll-y>

      <!-- 堂食/外带标签 -->
      <view class="cart-type-bar">
        <view class="cart-type-tag">
          <text class="cart-type-text">{{orderType === 'dine-in' ? '堂食' : '外带'}}</text>
        </view>
      </view>

      <!-- 商品条目 -->
      <view class="cart-list">
        <view class="cart-item" wx:for="{{cartList}}" wx:key="uid">
          <image src="{{item.image}}" class="cart-item-img" mode="aspectFill"></image>
          <view class="cart-item-info">
            <text class="cart-item-name">{{item.name}}</text>
            <text wx:if="{{item.temp}}" class="cart-item-temp">{{item.temp}}</text>
            <text class="cart-item-price">¥{{item.price}}</text>
          </view>
          <view class="cart-item-qty-row">
            <view class="qty-btn" bindtap="onDecQty" data-uid="{{item.uid}}">
              <text class="qty-btn-text">−</text>
            </view>
            <text class="qty-num">{{item.qty}}</text>
            <view class="qty-btn" bindtap="onIncQty" data-uid="{{item.uid}}">
              <text class="qty-btn-text">+</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 备注 -->
      <view class="cart-remark-card">
        <text class="cart-remark-label">备注</text>
        <input
          class="cart-remark-input"
          value="{{remark}}"
          placeholder="口味偏好、过敏信息等..."
          placeholder-class="cart-remark-placeholder"
          bindinput="onRemarkInput"
        />
      </view>

    </scroll-view>

    <!-- 底部结算栏 -->
    <view class="cart-footer">
      <view class="cart-footer-left">
        <text class="cart-total-label">合计</text>
        <text class="cart-total-price">¥{{totalPrice}}</text>
        <text class="cart-total-count">共{{totalCount}}件</text>
      </view>
      <view class="cart-submit-btn" bindtap="onSubmitOrder">
        <text class="cart-submit-text">提交订单</text>
      </view>
    </view>
  </block>

</view>
