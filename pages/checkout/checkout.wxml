<!--checkout.wxml-->
<navigation-bar title="确认支付" back="{{true}}" color="#5B3A29" background="#F9F6F0"></navigation-bar>

<view class="co-page">

  <!-- 订单类型 -->
  <view class="co-section">
    <view class="co-type-tag">
      <text class="co-type-text">{{orderType === 'dine-in' ? '堂食' : '外带'}}</text>
    </view>
  </view>

  <!-- 商品明细 -->
  <view class="co-section co-card">
    <text class="co-section-title">订单明细</text>
    <view class="co-item-list">
      <view class="co-item" wx:for="{{cartList}}" wx:key="uid">
        <image src="{{item.image}}" class="co-item-img" mode="aspectFill"></image>
        <view class="co-item-info">
          <text class="co-item-name">{{item.name}}</text>
          <text wx:if="{{item.temp}}" class="co-item-temp">{{item.temp}}</text>
        </view>
        <view class="co-item-right">
          <text class="co-item-qty">×{{item.qty}}</text>
          <text class="co-item-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="co-section co-card" wx:if="{{remark}}">
    <text class="co-remark-label">备注</text>
    <text class="co-remark-text">{{remark}}</text>
  </view>

  <!-- 合计 -->
  <view class="co-section co-card co-total-row">
    <text class="co-total-label">合计</text>
    <text class="co-total-price">¥{{totalPrice}}</text>
  </view>

  <!-- 支付方式 -->
  <view class="co-section co-card">
    <text class="co-section-title">支付方式</text>
    <view class="co-pay-method">
      <image src="/images/icons/wechat-pay.png" class="co-pay-icon" mode="aspectFit"></image>
      <text class="co-pay-name">微信支付</text>
      <view class="co-pay-check">
        <text class="co-pay-check-dot">●</text>
      </view>
    </view>
  </view>

</view>

<!-- 底部支付按钮 -->
<view class="co-footer">
  <view class="co-footer-inner">
    <view class="co-amount-row">
      <text class="co-footer-label">实付</text>
      <text class="co-footer-price">¥{{totalPrice}}</text>
    </view>
    <view class="co-pay-btn {{paying ? 'co-pay-btn-disabled' : ''}}" bindtap="onPay">
      <text class="co-pay-btn-text">{{paying ? '支付中...' : '立即支付'}}</text>
    </view>
  </view>
</view>
