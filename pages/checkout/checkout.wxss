/**checkout.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F9F6F0;
}

.co-page {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 32rpx 200rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== section ========== */
.co-section {
  display: flex;
  flex-direction: column;
}

.co-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  gap: 20rpx;
}

.co-section-title {
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.55);
  margin-bottom: 4rpx;
}

/* ========== 订单类型 ========== */
.co-type-tag {
  align-self: flex-start;
  background: rgba(163, 33, 45, 0.10);
  border-radius: 12rpx;
  padding: 10rpx 28rpx;
}

.co-type-text {
  font-size: 26rpx;
  color: #A3212D;
  font-weight: 500;
}

/* ========== 商品条目 ========== */
.co-item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.co-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.co-item-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  background: #F0E8DF;
  flex-shrink: 0;
}

.co-item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.co-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3A2318;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.co-item-temp {
  font-size: 22rpx;
  color: rgba(58, 35, 24, 0.50);
  background: #F0E8DF;
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
  align-self: flex-start;
}

.co-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.co-item-qty {
  font-size: 24rpx;
  color: rgba(58, 35, 24, 0.45);
}

.co-item-price {
  font-size: 28rpx;
  color: #A3212D;
  font-weight: 500;
}

/* ========== 备注 ========== */
.co-remark-label {
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.55);
}

.co-remark-text {
  font-size: 28rpx;
  color: #3A2318;
}

/* ========== 合计 ========== */
.co-total-row {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.co-total-label {
  font-size: 28rpx;
  color: rgba(58, 35, 24, 0.60);
}

.co-total-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #A3212D;
}

/* ========== 支付方式 ========== */
.co-pay-method {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.co-pay-icon {
  width: 48rpx;
  height: 48rpx;
}

.co-pay-name {
  flex: 1;
  font-size: 28rpx;
  color: #3A2318;
}

.co-pay-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #A3212D;
  display: flex;
  align-items: center;
  justify-content: center;
}

.co-pay-check-dot {
  font-size: 20rpx;
  color: #FFFFFF;
}

/* ========== 底部按钮 ========== */
.co-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-top: 1rpx solid #F0E8DF;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
}

.co-footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.co-amount-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.co-footer-label {
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.60);
}

.co-footer-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #A3212D;
}

.co-pay-btn {
  height: 88rpx;
  padding: 0 72rpx;
  background: #A3212D;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.co-pay-btn-disabled {
  opacity: 0.6;
}

.co-pay-btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
}
