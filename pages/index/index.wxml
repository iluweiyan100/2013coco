<!--index.wxml-->
<!-- 导航栏 -->
<view class="navbar" style="padding-top: {{statusBarHeight}}px; height: calc({{statusBarHeight}}px + 44px);">
  <view class="navbar-content">
    <text class="navbar-title">贰零壹叁咖啡馆</text>
  </view>
</view>

<!-- 占位空间，防止内容被导航栏遮挡 -->
<view class="navbar-placeholder" style="height: calc({{statusBarHeight}}px + 44px);"></view>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    
    <!-- Banner 轮播图 -->
    <view class="banner-container">
      <!-- 有自定义图片时：swiper 轮播 -->
      <swiper
        wx:if="{{heroImages.length > 0}}"
        class="banner-swiper"
        autoplay
        interval="3500"
        circular
        indicator-dots="{{false}}"
      >
        <swiper-item wx:for="{{heroImages}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill" class="banner-image"></image>
        </swiper-item>
      </swiper>

      <!-- 无自定义图片时：显示品牌色占位背景（通过 CSS 处理） -->
      <view wx:else class="banner-placeholder"></view>
    </view>

    <!-- 堂食/外带选择区 -->
    <view class="dining-options">
      <!-- 堂食 -->
      <view class="option-card" bindtap="onDineInTap">
        <view class="option-icon dine-in-icon">
          <image src="/images/icons/dine-in.svg" class="option-svg" mode="aspectFit"></image>
        </view>
        <view class="option-content">
          <text class="option-title">堂食</text>
          <text class="option-desc">店内享用</text>
        </view>
      </view>

      <!-- 外带 -->
      <view class="option-card" bindtap="onTakeawayTap">
        <view class="option-icon takeaway-icon">
          <image src="/images/icons/takeaway.svg" class="option-svg" mode="aspectFit"></image>
        </view>
        <view class="option-content">
          <text class="option-title">外带</text>
          <text class="option-desc">打包带走</text>
        </view>
      </view>
    </view>

    <!-- WiFi 连接按钮 -->
    <view class="wifi-button" bindtap="onConnectWifi">
      <image src="/public/images/wifi.svg" class="wifi-icon-svg" mode="aspectFit"></image>
      <text class="wifi-text">店内WiFi</text>
      <text class="arrow">→</text>
    </view>

    <!-- 店员和管理入口 -->
    <view class="staff-section">
      <view class="staff-btn staff-mode" bindtap="onStaffMode">
        <view class="btn-icon">
          <view class="icon-shield"></view>
        </view>
        <text class="btn-text">店员制作端</text>
      </view>
      
      <view class="staff-btn admin-mode" bindtap="onAdminMode">
        <view class="btn-icon">
          <view class="icon-settings"></view>
        </view>
        <text class="btn-text">管理后台</text>
      </view>
    </view>

  </view>
</scroll-view>
