/**order.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F9F5F0; /* RGB(249, 245, 240) */
}

.order-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 主内容区：双栏布局 ========== */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
  /* 确保内容从导航栏下方开始 */
  height: 100%;
}

/* 左侧分类导航 - 宽度 96px = 192rpx */
.category-sidebar {
  width: 192rpx;
  background: #E7DCD1; /* RGB(231, 221, 209) */
  height: 100%; /* 自动适应父容器高度，与右侧商品列表等高 */
  padding-top: 20rpx;
  overflow-y: auto; /* 如果分类过多，允许滚动 */
}

.sidebar-item {
  padding: 26rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #5A3A29;
  position: relative;
}

.sidebar-item.active {
  background: #FFFFFF;
  color: #A3212D;
  font-weight: 500;
}

/* 右侧商品列表 - 宽度自适应 */
.product-list {
  flex: 1;
  background: #F9F5F0; /* 确保背景色覆盖 */
  height: 100%;
  padding: 20rpx 20rpx 0;
}

/* 分类标题 */
.category-title {
  padding: 24rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #5A3A29;
}

/* 第一个分类标题不需要顶部间距 */
.category-title:first-child {
  padding-top: 0;
}

/* 商品卡片 - 紧凑布局 */
.product-card {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  min-height: auto;
  height: auto;
}

/* 最后一个商品卡片不需要底部边距（由容器 padding-bottom 控制） */
.product-card:last-child {
  margin-bottom: 0;
}

/* 商品图片 - 80×80px = 160×160rpx */
.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #F5F5F5; /* 图片加载前的占位背景 */
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 8rpx;
  min-width: 0; /* 允许文本截断 */
}

/* 卡片底部：价格左 + 加减号右 */
.product-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

/* 规格标签组 */
.spec-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.spec-tag {
  font-size: 22rpx;
  color: #A3212D;
  background: #FAF0EE;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  line-height: 1.4;
}

.product-name {
  font-size: 32rpx; /* 16px */
  font-weight: 500;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 32rpx; /* 16px */
  font-weight: 600;
  color: #A3212D;
  line-height: 1.2;
}

.product-desc {
  font-size: 24rpx; /* 12px */
  color: #999999;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 添加按钮 - 24px = 48rpx */
.add-btn {
  width: 48rpx;
  height: 48rpx;
  background: #A3212D;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  cursor: pointer;
  transition: opacity 0.2s;
}

/* 数量控制区：减号 + 数字 + 加号 */
.qty-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.minus-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #A3212D;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.minus-line {
  width: 20rpx;
  height: 2rpx;
  background: #A3212D;
  border-radius: 2rpx;
}

.qty-num {
  font-size: 24rpx;
  font-weight: 600;
  color: #3A2318;
  min-width: 28rpx;
  text-align: center;
}

/* ========== 规格选择小浮窗 ========== */
.spec-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 300;
}

.spec-popup {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  z-index: 301;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
  box-sizing: border-box;
}

.spec-popup-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #3A2318;
  text-align: center;
  margin-bottom: 8rpx;
}

.spec-popup-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(58, 35, 24, 0.55);
  text-align: center;
  margin-bottom: 36rpx;
}

.spec-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

/* 堂食/外带横排 */
.spec-options-row {
  flex-direction: row;
  gap: 16rpx;
}

.spec-option-half,
.spec-option-flex {
  flex: 1;
}

.spec-option {
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E7DDD1;
  background: #FAF6F2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spec-option-active {
  border-color: #A3212D;
  background: rgba(163, 33, 45, 0.07);
}

.spec-option-text {
  font-size: 28rpx;
  color: #5A3A29;
}

.spec-option-text-active {
  color: #A3212D;
  font-weight: 500;
}

.spec-actions {
  display: flex;
  gap: 20rpx;
}

.spec-cancel-btn {
  flex: 1;
  height: 80rpx;
  background: #F5EDE4;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spec-cancel-text {
  font-size: 28rpx;
  color: #8B6F5E;
}

.spec-confirm-btn {
  flex: 1;
  height: 80rpx;
  background: #A3212D;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spec-confirm-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.add-btn:active {
  opacity: 0.7;
}

.icon-plus {
  position: relative;
  width: 26rpx;
  height: 26rpx;
}

.plus-h,
.plus-v {
  position: absolute;
  background: #FFFFFF;
  border-radius: 1rpx;
}

.plus-h {
  width: 26rpx;
  height: 2rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

.plus-v {
  width: 2rpx;
  height: 26rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== TabBar ========== */
.tabbar {
  position: fixed;
  bottom: -50rpx; /* 向下移动 25px (50rpx) */
  left: 0;
  right: 0;
  height: 128rpx; /* 固定高度，禁止修改 */
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #E5E5E5;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom); /* 底部安全区域适配 */
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.tab-svg {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.tab-label {
  font-size: 24rpx;
  color: #999999;
}

.tab-item.active .tab-svg {
  filter: brightness(0) saturate(100%) invert(23%) sepia(85%) saturate(1765%) hue-rotate(335deg) brightness(92%) contrast(96%);
}

.tab-item.active .tab-label {
  color: #A3212D;
  font-weight: 500;
}

/* 商品列表底部占位，确保最后一个卡片距底部 20px */
.product-list-spacer {
  height: 40rpx;
  flex-shrink: 0;
}

/* ========== 购物车悬浮按钮 ========== */
.cart-fab {
  position: fixed;
  left: 48rpx;
  bottom: 160rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 200;
}

.cart-fab-icon {
  width: 56rpx;
  height: 56rpx;
}

.cart-fab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #A3212D;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
  border: 3rpx solid #FFFFFF;
}

.cart-fab-badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}
