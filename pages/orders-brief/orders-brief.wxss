/* pages/orders-brief/orders-brief.wxss */

/* ========== 导航栏 ========== */
.navbar {
  width: 100%;
  background: white;
  border-bottom: 1.3rpx #E7DDD1 solid;
  display: flex;
  align-items: center;
  justify-content: center;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  box-sizing: border-box;
}

.navbar-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.back-btn {
  position: absolute;
  left: 32rpx;
  height: 44px;
  display: flex;
  align-items: center;
}

.back-icon {
  width: 24px;
  height: 24px;
  color: #5B3A29;
}

.navbar-title {
  font-size: 40rpx;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 500;
  line-height: 44px;
}

/* ========== 容器 ========== */
.orders-brief-container {
  min-height: 100vh;
  background: #F9F5F0;
  padding-bottom: 32rpx;
}

.navbar-placeholder {
  width: 100%;
}

/* ========== 订单列表 ========== */
.orders-list {
  height: calc(100vh - 121.3rpx);
  padding: 32rpx 16rpx;
  padding-bottom: calc(32rpx + 30px);
  box-sizing: border-box;
}

/* ========== 订单卡片 ========== */
.order-card {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 订单简要信息 */
.order-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pickup-number {
  font-size: 44rpx;
  color: #A3212D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 500;
}

.order-type {
  padding: 4rpx 12rpx;
  background: rgba(163, 33, 45, 0.10);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #A3212D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 500;
}

.order-right {
  display: flex;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: rgba(91, 58, 41, 0.50);
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

/* 商品简要 */
.product-brief {
  margin-bottom: 20rpx;
}

.product-text {
  font-size: 26rpx;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 底部信息 */
.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0E8DF;
}

.total-price {
  font-size: 36rpx;
  color: #A3212D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 600;
}

.product-count {
  font-size: 24rpx;
  color: rgba(91, 58, 41, 0.50);
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 240rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
}
