<!-- pages/orders/orders.wxml -->
<view class="orders-container">
  <!-- 导航栏 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px; height: calc({{statusBarHeight}}px + 44px);">
    <view class="navbar-content">
      <text class="navbar-title">我的订单</text>
    </view>
  </view>

  <!-- 占位空间，防止内容被导航栏遮挡 -->
  <view class="navbar-placeholder" style="height: calc({{statusBarHeight}}px + 44px);"></view>

  <!-- Tab 切换区 -->
  <view class="tab-container">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="onTabChange" data-tab="all">
      <text class="tab-text">全部</text>
    </view>
    <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="onTabChange" data-tab="pending">
      <text class="tab-text">待使用</text>
    </view>
    <view class="tab-item {{currentTab === 'completed' ? 'active' : ''}}" bindtap="onTabChange" data-tab="completed">
      <text class="tab-text">已完成</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="orders-list" scroll-y="true">
    <block wx:for="{{filteredOrders}}" wx:key="id">
      <view class="order-card">
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="pickup-section">
            <view class="pickup-row">
              <text class="pickup-label">取餐号</text>
              <text class="pickup-number">{{item.pickupNumber}}</text>
            </view>
            <view class="order-info">
              <text class="order-date">{{item.date}}</text>
              <text class="order-time">{{item.time}}</text>
              <text class="order-type" style="position: relative; left: 57rpx; top: -62rpx">{{item.orderType}}</text>
            </view>
          </view>
          <view class="status-section">
            <image class="status-icon" src="/assets/CodeBuddyAssets/64_2/{{item.statusIcon}}.svg" mode="aspectFit"></image>
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>

        <!-- 商品列表 -->
        <view class="product-list" style="height: 81rpx; display: block; box-sizing: border-box">
          <block wx:for="{{item.products}}" wx:for-item="product" wx:key="index">
            <view class="product-item">
              <view class="product-info">
                <text class="product-name">{{product.name}}</text>
                <text wx:if="{{product.option}}" class="product-option">{{product.option}}</text>
                <text class="product-quantity">x{{product.quantity}}</text>
              </view>
              <text class="product-price">¥{{product.price}}</text>
            </view>
          </block>
        </view>

        <!-- 合计 -->
        <view class="order-footer">
          <text class="total-label">合计</text>
          <text class="total-amount">¥{{item.totalAmount}}</text>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{filteredOrders.length === 0}}" class="empty-state">
      <text class="empty-text">暂无订单</text>
    </view>
  </scroll-view>
</view>
