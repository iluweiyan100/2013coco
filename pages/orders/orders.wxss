/* pages/orders/orders.wxss */

/* ========== 导航栏 ========== */
.navbar {
  width: 100%;
  background: white;
  border-bottom: 1.3rpx #E7DDD1 solid;
  display: flex;
  align-items: center;
  justify-content: center;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  box-sizing: border-box;
}

.navbar-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 40rpx !important;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC !important;
  font-weight: 500 !important;
  line-height: 44px;
}

/* ========== 容器 ========== */
.orders-container {
  min-height: 100vh;
  background: #F9F5F0;
  padding-bottom: 129.3rpx;
}

.navbar-placeholder {
  width: 100%;
}

/* ========== Tab 切换区 ========== */
.tab-container {
  margin: 32rpx 16rpx;
  height: 72rpx;
  background: #E7DDD1;
  border-radius: 32rpx;
  display: flex;
  position: relative;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #A3212D;
}

.tab-text {
  font-size: 28rpx;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: white;
}

/* ========== 订单列表 ========== */
.orders-list {
  height: calc(100vh - 121.3rpx - 129.3rpx);
  padding: 0 16rpx 32rpx;
  box-sizing: border-box;
}

/* ========== 订单卡片 ========== */
.order-card {
  background: white;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0px 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.10),
              0px 2rpx 6rpx rgba(0, 0, 0, 0.10);
  overflow: hidden;
}

/* 订单头部 */
.order-header {
  padding: 32rpx 32rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.pickup-section {
  flex: 1;
}

.pickup-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.pickup-label {
  font-size: 32rpx;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
  margin-right: 16rpx;
}

.pickup-number {
  font-size: 48rpx;
  color: #A3212D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

.order-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-date,
.order-time {
  font-size: 28rpx;
  color: rgba(91, 58, 41, 0.60);
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

.order-type {
  padding: 4rpx 16rpx;
  background: #E7DDD1;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: rgba(91, 58, 41, 0.60);
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

/* 状态部分 */
.status-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-icon {
  width: 24rpx;
  height: 24rpx;
}

.status-text {
  font-size: 28rpx;
  color: #A3212D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

/* ========== 商品列表 ========== */
.product-list {
  border-top: 1.3rpx #E7DDD1 solid;
  padding: 16rpx 32rpx;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  height: 48rpx;
}

.product-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 48rpx;
}

.product-name {
  font-size: 28rpx;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
  line-height: 48rpx;
}

.product-option {
  font-size: 24rpx;
  color: rgba(91, 58, 41, 0.50);
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
  line-height: 48rpx;
}

.product-quantity {
  font-size: 28rpx;
  color: rgba(91, 58, 41, 0.50);
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
  line-height: 48rpx;
}

.product-price {
  font-size: 28rpx;
  color: #C08A4D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
  line-height: 48rpx;
  text-align: right;
}

/* ========== 订单底部 ========== */
.order-footer {
  padding: 29.3rpx 32rpx 32rpx;
  border-top: 1.3rpx #E7DDD1 solid;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: 32rpx;
  color: #5B3A29;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

.total-amount {
  font-size: 40rpx;
  color: #C08A4D;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
  font-weight: 400;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 240rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  font-family: 'CangerShuYuanTi', Noto Serif SC;
}
