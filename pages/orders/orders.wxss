/* pages/orders/orders.wxss */

.orders-container {
  min-height: 100vh;
  background: #F9F5F0;
  display: flex;
  flex-direction: column;
  padding: 0 32rpx; /* 左右边距由容器统一控制 */
  padding-bottom: 128rpx; /* 为底部 TabBar 留出空间 */
}

/* ========== 当前订单状态区 ========== */
.current-order-section {
  background: linear-gradient(135deg, #A3212D 0%, #C08A4D 100%);
  padding: 48rpx 32rpx; /* 恢复左右 padding，与容器保持一致 */
  margin: 0 -32rpx; /* 使用负 margin 突破容器边距，铺满屏幕 */
  color: #FFFFFF;
}

.section-label {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 16rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pickup-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pickup-number {
  font-size: 72rpx;
  font-weight: 400;
  line-height: 1;
}

.order-status {
  font-size: 28rpx;
  opacity: 0.9;
}

/* ========== Tab 切换区 ========== */
.tab-container {
  display: flex;
  background: transparent;
  border-radius: 0;
  padding: 0;
  margin: 32rpx 0 0; /* 移除左右 margin，由父容器 padding 控制 */
  gap: 32rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 0;
  transition: all 0.3s;
}

.tab-item text {
  font-size: 28rpx;
  color: #5A3A29;
  opacity: 0.6;
  font-weight: 400;
}

.tab-item.active text {
  color: #A3212D;
  font-weight: 500;
  opacity: 1;
}

/* ========== 订单列表 ========== */
.orders-list {
  flex: 1;
  padding: 32rpx 0; /* 只保留上下内边距，左右由父容器控制 */
}

.order-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 
    0 -2rpx 4rpx rgba(0, 0, 0, 0.1),
    0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

/* 订单卡片头部 */
.order-card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.left-section {
  flex: 1;
}

.pickup-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.pickup-label {
  font-size: 32rpx;
  color: #5A3A29;
}

.pickup-value {
  font-size: 48rpx;
  color: #A3212D;
  font-weight: 400;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-text,
.time-text {
  font-size: 28rpx;
  color: #5A3A29;
  opacity: 0.6;
}

.type-tag {
  font-size: 24rpx;
  color: #5A3A29;
  opacity: 0.6;
  background: #E8DCD1;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.right-section {
  display: flex;
  align-items: center;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-icon {
  width: 32rpx;
  height: 32rpx;
}

.status-text {
  font-size: 28rpx;
  color: #A3212D;
}

/* 商品列表 */
.product-list {
  border-top: 2rpx solid #E8DCD1;
  padding-top: 24rpx;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.product-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.product-name {
  font-size: 28rpx;
  color: #5A3A29;
}

.product-option {
  font-size: 24rpx;
  color: #5A3A29;
  opacity: 0.5;
}

.product-quantity {
  font-size: 28rpx;
  color: #5A3A29;
  opacity: 0.5;
}

.product-price {
  font-size: 28rpx;
  color: #C08A4D;
}

/* 合计 */
.order-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2rpx solid #E8DCD1;
  padding-top: 24rpx;
  margin-top: 8rpx;
}

.total-label {
  font-size: 32rpx;
  color: #5A3A29;
}

.total-amount {
  font-size: 40rpx;
  color: #C08A4D;
  font-weight: 400;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== 底部 TabBar ========== */
.tabbar {
  position: fixed;
  bottom: -50rpx; /* 向下移动 25px (50rpx)，与首页保持一致 */
  left: 0;
  right: 0;
  height: 128rpx; /* 固定高度，禁止修改 */
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #E5E5E5;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom); /* 底部安全区域适配 */
}

.tabbar .tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.tab-svg {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.tab-label {
  font-size: 24rpx;
  color: #999999;
}

.tabbar .tab-item.active .tab-svg {
  filter: brightness(0) saturate(100%) invert(23%) sepia(85%) saturate(1765%) hue-rotate(335deg) brightness(92%) contrast(96%);
}

.tabbar .tab-item.active .tab-label {
  color: #A3212D;
  font-weight: 500;
}
