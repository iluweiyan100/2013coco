<!-- pages/profile/profile.wxml -->
<!-- 导航栏 -->
<view class="navbar" style="padding-top: {{statusBarHeight}}px; height: calc({{statusBarHeight}}px + 44px);">
  <view class="navbar-content">
    <text class="navbar-title">我 的</text>
  </view>
</view>

<!-- 占位空间，防止内容被导航栏遮挡 -->
<view class="navbar-placeholder" style="height: calc({{statusBarHeight}}px + 44px);"></view>

<view class="profile-container">

  <!-- 登录前状态 -->
  <block wx:if="{{!isLogin}}">
    <!-- 未登录头部 -->
    <view class="unlogin-header">
      <!-- 头像选择 -->
      <view class="avatar-circle">
        <button open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" class="avatar-button">
          <image src="{{tempAvatarUrl || '/images/icons/profile.svg'}}" class="avatar-icon" mode="aspectFill"></image>
        </button>
      </view>

      <!-- 昵称输入 -->
      <view class="nickname-input-wrapper">
        <input type="nickname" class="nickname-input" placeholder="请输入昵称" bindinput="onNicknameInput" value="{{tempNickname}}" />
      </view>

      <!-- 手机号输入 -->
      <view class="phone-input-wrapper">
        <input type="number" class="phone-input" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{tempPhone}}" maxlength="11" />
      </view>

      <!-- 登录按钮 -->
      <view class="login-button-wrapper">
        <text class="login-button-text" bindtap="onLogin">确认登录</text>
      </view>
    </view>
  </block>

  <!-- 登录后状态 -->
  <block wx:else>
    <!-- 用户信息头部 -->
    <view class="user-info-header">
      <!-- 用户信息卡片（悬浮效果） -->
      <view class="user-card">
        <!-- 用户头像 -->
        <image src="{{userInfo.avatarUrl || '/images/icons/profile.svg'}}" class="user-avatar" mode="aspectFill"></image>

        <!-- 用户信息 -->
        <view class="user-details">
          <text class="user-nickname">{{userInfo.nickName || '微信用户'}}</text>
          <text class="user-phone">{{userInfo.phone || '未绑定手机号'}}</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单列表 -->
    <view class="menu-list">
      <!-- 我的订单 -->
      <view class="menu-button" bindtap="onMenuItem" data-action="orders">
        <view class="menu-left">
          <view class="icon-circle">
            <image src="/images/icons/myorder.svg" class="menu-icon" mode="aspectFit"></image>
          </view>
          <text class="menu-text">我的订单</text>
        </view>
      </view>

      <!-- 联系客服 -->
      <button class="menu-button" open-type="contact" session-from="profile" bindcontact="onContactMessage" style="width: 689rpx; display: flex; box-sizing: border-box; left: 0rpx; top: 0rpx">
        <view class="menu-left">
          <view class="icon-circle">
            <image src="/public/images/kefu.svg" class="menu-icon" mode="aspectFit"></image>
          </view>
          <text class="menu-text">联系客服</text>
        </view>
      </button>

      <!-- 设置 -->
      <view class="menu-button" bindtap="onMenuItem" data-action="settings">
        <view class="menu-left">
          <view class="icon-circle">
            <image src="/public/images/setting.svg" class="menu-icon" mode="aspectFit"></image>
          </view>
          <text class="menu-text">设置</text>
        </view>
      </view>
    </view>
  </block>

</view>
