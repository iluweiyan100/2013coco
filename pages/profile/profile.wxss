/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: #F9F5F0;
  display: flex;
  flex-direction: column;
  padding-bottom: 128rpx;
}

.unlogin-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 280rpx;
  gap: 24rpx;
}

.avatar-circle {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  background: #E7DCD1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-button {
  width: 100%;
  height: 100%;
  padding: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  font-weight: 400 !important;
}

.avatar-button::after {
  border: none;
}

.avatar-icon {
  width: 192rpx;
  height: 192rpx;
  opacity: 1;
}

.nickname-input-wrapper {
  width: 480rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #E7DCD1;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 28rpx;
  background: #FFFFFF;
  color: #5A3A29;
  text-align: center;
}

.nickname-input::placeholder {
  color: #B8A99E;
}

.phone-input-wrapper {
  width: 480rpx;
}

.phone-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #E7DCD1;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 28rpx;
  background: #FFFFFF;
  color: #5A3A29;
  text-align: center;
}

.phone-input::placeholder {
  color: #B8A99E;
}

.welcome-title {
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 40rpx;
  color: #5A3A29;
  line-height: 60rpx;
  text-align: center;
}

.login-desc {
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 28rpx;
  color: #5A3A29;
  opacity: 0.6;
  line-height: 40rpx;
  text-align: center;
}

.login-button {
  margin-top: 32rpx;
  background: #A3212D;
  color: #FFFFFF;
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 28rpx;
  padding: 16rpx 64rpx;
  border-radius: 20rpx;
  border: none;
  line-height: 40rpx;
  box-shadow: none;
}

.login-button::after {
  border: none;
}

.user-info-header {
  background: linear-gradient(135deg, #C08A4D 0%, #D4A574 50%, #E8C9A0 100%);
  padding: 48rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.user-info-header::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}

.user-info-header::after {
  content: '';
  position: absolute;
  bottom: -150rpx;
  left: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.user-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(0, 0, 0, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(192, 138, 77, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  background: #E7DCD1;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-nickname {
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 36rpx;
  color: #5A3A29;
  line-height: 52rpx;
}

.user-phone {
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 28rpx;
  color: #8B6F5E;
  line-height: 40rpx;
}

.menu-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.menu-button {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  box-shadow: 
    0 -2rpx 4rpx rgba(0, 0, 0, 0.1),
    0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E7DCD1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  font-family: 'Noto Serif SC', serif;
  font-weight: 400 !important;
  font-size: 32rpx;
  color: #5A3A29;
  line-height: 48rpx;
}

.tabbar {
  position: fixed;
  bottom: -50rpx;
  left: 0;
  right: 0;
  height: 128rpx;
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #E5E5E5;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.tab-svg {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.tab-label {
  font-family: 'Noto Serif SC', serif;
  font-weight: 400;
  font-size: 24rpx;
  color: #999999;
}

.tab-item.active .tab-svg {
  filter: brightness(0) saturate(100%) invert(23%) sepia(85%) saturate(1765%) hue-rotate(335deg) brightness(92%) contrast(96%);
}

.tab-item.active .tab-label {
  color: #A3212D;
  font-weight: 400;
}
