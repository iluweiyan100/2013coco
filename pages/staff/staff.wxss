/* staff.wxss */
.staff-container {
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

/* ========== 左栏：新订单（2/3） ========== */
.new-orders-section {
  flex: 2;
  display: flex;
  flex-direction: column;
  border-right: 4rpx solid #e0e0e0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background: #ffffff;
  border-bottom: 2rpx solid #e0e0e0;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3B1F0F;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
}

.refresh-icon {
  font-size: 36rpx;
  color: #666666;
}

/* 新订单区域的堂食/外带容器 */
.orders-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 订单类型区域 */
.order-type-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.type-header {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  background: #fafafa;
  border-bottom: 2rpx solid #e0e0e0;
}

.type-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3B1F0F;
  margin-right: 10rpx;
}

.type-count {
  font-size: 28rpx;
  color: #999999;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 20rpx;
}

.empty-tip {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 订单卡片 */
.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 堂食订单：橙色左边框 */
.dine-card {
  border-left: 8rpx solid #FF6B35;
}

/* 外带订单：蓝色左边框 */
.takeaway-card {
  border-left: 8rpx solid #4A90E2;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.pickup-no-wrapper {
  display: flex;
  align-items: center;
}

.pickup-no {
  font-size: 64rpx;
  font-weight: bold;
  color: #FF6B35;
  letter-spacing: 4rpx;
}

.order-time {
  font-size: 28rpx;
  color: #999999;
}

/* 商品明细 */
.items-divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.order-items {
  margin-bottom: 20rpx;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  color: #333333;
  margin-right: 15rpx;
}

.item-temp {
  font-size: 24rpx;
  color: #FF6B35;
  background: #FFF0E8;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.item-qty {
  font-size: 24rpx;
  color: #999999;
}

.item-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #3B1F0F;
}

/* 备注 */
.order-remark {
  background: #FFF9E6;
  padding: 15rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.remark-label {
  font-size: 26rpx;
  color: #FF9800;
  margin-right: 10rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #666666;
}

.card-divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 完成按钮 */
.complete-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #FF6B35;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  border-radius: 12rpx;
}

.complete-btn:active {
  background: #E55A2B;
  transform: scale(0.98);
}

/* ========== 右栏：已完成（1/3）- 灰色 ========== */
.completed-orders-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.section-count {
  font-size: 28rpx;
  color: #999999;
}

.completed-list {
  flex: 1;
  padding: 20rpx;
}

/* 已完成卡片 - 灰色 */
.completed-card {
  background: #e0e0e0;
  opacity: 0.7;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  border-left: 6rpx solid #999999;
}

.completed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.completed-pickup-no {
  font-size: 48rpx;
  font-weight: bold;
  color: #999999;
}

.completed-type {
  font-size: 24rpx;
  color: #666666;
  background: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.completed-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.completed-time {
  font-size: 24rpx;
  color: #666666;
}

.completed-total {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
}

/* ===== iPad 横屏适配（所有尺寸用 px，避免 rpx 随宽屏放大） ===== */
@media (orientation: landscape) and (min-width: 600px) {

  .staff-container {
    height: 100vh;
  }

  /* 左栏比例更大 */
  .new-orders-section {
    flex: 3;
    border-right: 2px solid #e0e0e0;
  }

  /* section 标题栏 */
  .section-header {
    padding: 10px 16px;
  }

  .section-title {
    font-size: 15px;
  }

  .refresh-btn {
    width: 28px;
    height: 28px;
  }

  .refresh-icon {
    font-size: 16px;
  }

  /* 堂食/外带改为左右并排 */
  .orders-body {
    flex-direction: row;
  }

  .order-type-section {
    border-right: 1px solid #e0e0e0;
  }

  .order-type-section:last-child {
    border-right: none;
  }

  /* 类型标题栏 */
  .type-header {
    padding: 8px 14px;
  }

  .type-title {
    font-size: 13px;
    margin-right: 4px;
  }

  .type-count {
    font-size: 12px;
  }

  /* 订单列表内边距 */
  .order-list {
    padding: 8px;
  }

  /* 订单卡片 */
  .order-card {
    padding: 10px 12px;
    margin-bottom: 8px;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.07);
  }

  .dine-card {
    border-left: 4px solid #FF6B35;
  }

  .takeaway-card {
    border-left: 4px solid #4A90E2;
  }

  .card-header {
    margin-bottom: 8px;
  }

  /* 取号大字 */
  .pickup-no {
    font-size: 28px;
    letter-spacing: 1px;
  }

  .order-time {
    font-size: 11px;
  }

  /* 商品明细 */
  .items-divider {
    margin: 6px 0;
  }

  .order-items {
    margin-bottom: 6px;
  }

  .item-row {
    padding: 5px 0;
  }

  .item-name {
    font-size: 13px;
    margin-right: 6px;
  }

  .item-temp {
    font-size: 11px;
    padding: 2px 5px;
    margin-right: 6px;
  }

  .item-qty {
    font-size: 11px;
  }

  .item-price {
    font-size: 13px;
  }

  /* 备注 */
  .order-remark {
    padding: 6px 8px;
    margin-bottom: 6px;
  }

  .remark-label,
  .remark-text {
    font-size: 11px;
  }

  .card-divider {
    margin: 6px 0;
  }

  /* 完成按钮 */
  .complete-btn {
    height: 34px;
    line-height: 34px;
    font-size: 13px;
    border-radius: 6px;
  }

  /* 已完成栏固定宽度 */
  .completed-orders-section {
    flex: 0 0 200px;
    min-width: 200px;
  }

  .completed-list {
    padding: 8px;
  }

  .completed-card {
    padding: 8px 10px;
    margin-bottom: 8px;
    border-radius: 6px;
    border-left: 3px solid #999999;
  }

  .completed-pickup-no {
    font-size: 22px;
  }

  .completed-type {
    font-size: 11px;
    padding: 2px 6px;
  }

  .completed-time {
    font-size: 11px;
  }

  .completed-total {
    font-size: 12px;
  }

  .section-count {
    font-size: 12px;
  }

  .empty-tip {
    padding: 40px 0;
  }

  .empty-text {
    font-size: 12px;
  }
}
